{
  "include": [
    "src/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "Node16",
    "target": "ES2022",
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "skipLibCheck": true
  }
}
